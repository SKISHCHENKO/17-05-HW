# Можно оставить cloud_id/folder_id закомментированными и использовать переменные окружения:
# export YC_TOKEN=$(yc iam create-token)
# export YC_CLOUD_ID=$(yc config get cloud-id)
# export YC_FOLDER_ID=$(yc config get folder-id)

# cloud_id  = "b1g..."
# folder_id = "b1g..."

default_zone = "ru-central1-a"

# Для учебного задания можно оставить 0.0.0.0/0.
# Безопаснее указать свой внешний IP, например "203.0.113.10/32".
allowed_ssh_cidr = "0.0.0.0/0"

ssh_user             = "ubuntu"
ssh_private_key_file = "~/.ssh/id_ed25519"
ssh_public_key       = "ssh-ed25519 AAAA... user@example"

preemptible = true
