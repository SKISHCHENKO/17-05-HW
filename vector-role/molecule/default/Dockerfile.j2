FROM {{ item.image }}

ENV container=docker

{% if item.image.startswith('ubuntu') %}
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y \
      python3 \
      python3-apt \
      sudo \
      systemd \
      systemd-sysv \
      dbus \
      curl \
      gnupg \
      ca-certificates \
      lsb-release \
      tar \
      gzip \
      xz-utils \
      unzip \
      procps \
      iproute2 && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

{% elif item.image.startswith('oraclelinux') %}

RUN dnf -y install \
      python39 \
      sudo \
      systemd \
      dbus \
      curl \
      gnupg2 \
      ca-certificates \
      tar \
      gzip \
      xz \
      unzip \
      procps-ng \
      iproute \
      hostname \
      shadow-utils \
      which && \
    dnf clean all

{% endif %}

VOLUME ["/sys/fs/cgroup"]

CMD ["/lib/systemd/systemd"]
